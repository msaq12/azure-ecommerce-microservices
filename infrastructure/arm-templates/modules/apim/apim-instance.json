{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "API Management instance for furniture dropshipping platform"
  },
  "parameters": {
    "apimName": {
      "type": "string",
      "metadata": {
        "description": "Name of APIM instance (must be globally unique)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "publisherEmail": {
      "type": "string",
      "metadata": {
        "description": "Email for notifications"
      }
    },
    "publisherName": {
      "type": "string",
      "defaultValue": "Furniture Dropship",
      "metadata": {
        "description": "Organization name"
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "Consumption",
      "allowedValues": [
        "Consumption",
        "Developer",
        "Basic",
        "Standard",
        "Premium"
      ],
      "metadata": {
        "description": "APIM SKU"
      }
    },
    "skuCount": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Number of scale units (0 for Consumption tier)"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": ["dev", "staging", "prod"]
    },
    "tags": {
      "type": "object",
      "defaultValue": {}
    }
  },
  "variables": {
    "defaultTags": {
      "Environment": "[parameters('environment')]",
      "Project": "FurnitureDropship",
      "ManagedBy": "ARM-Template",
      "Service": "ApiManagement"
    },
    "combinedTags": "[union(variables('defaultTags'), parameters('tags'))]"
  },
  "resources": [
    {
      "type": "Microsoft.ApiManagement/service",
      "apiVersion": "2023-05-01-preview",
      "name": "[parameters('apimName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('combinedTags')]",
      "sku": {
        "name": "[parameters('sku')]",
        "capacity": "[parameters('skuCount')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "publisherEmail": "[parameters('publisherEmail')]",
        "publisherName": "[parameters('publisherName')]",
        "notificationSenderEmail": "[parameters('publisherEmail')]",
        "virtualNetworkType": "None",
        "disableGateway": false,
        "apiVersionConstraint": {}
      }
    }
  ],
  "outputs": {
    "apimName": {
      "type": "string",
      "value": "[parameters('apimName')]"
    },
    "apimResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ApiManagement/service', parameters('apimName'))]"
    },
    "apimGatewayUrl": {
      "type": "string",
      "value": "[reference(parameters('apimName')).gatewayUrl]"
    }
  }
}
