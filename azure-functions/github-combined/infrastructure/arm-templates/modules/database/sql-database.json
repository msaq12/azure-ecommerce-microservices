{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Azure SQL Database for Furniture Dropshipping Platform"
  },
  "parameters": {
    "sqlServerName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing SQL Server"
      }
    },
    "databaseName": {
      "type": "string",
      "metadata": {
        "description": "Name of the SQL Database"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": ["Basic", "S0", "S1", "S2", "P1", "P2"],
      "metadata": {
        "description": "Database SKU (Basic for dev, S0+ for production)"
      }
    },
    "maxSizeBytes": {
      "type": "int",
      "defaultValue": 2147483648,
      "metadata": {
        "description": "Maximum database size in bytes (default 2GB)"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev"
    }
  },
  "variables": {
    "tags": {
      "Environment": "[parameters('environment')]",
      "Project": "FurnitureDropship",
      "Database": "[parameters('databaseName')]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-05-01-preview",
      "name": "[concat(parameters('sqlServerName'), '/', parameters('databaseName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "[parameters('skuName')]"
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS",
        "maxSizeBytes": "[parameters('maxSizeBytes')]",
        "catalogCollation": "SQL_Latin1_General_CP1_CI_AS",
        "zoneRedundant": false,
        "readScale": "Disabled",
        "requestedBackupStorageRedundancy": "Local"
      }
    }
  ],
  "outputs": {
    "databaseName": {
      "type": "string",
      "value": "[parameters('databaseName')]"
    },
    "databaseId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Sql/servers/databases', parameters('sqlServerName'), parameters('databaseName'))]"
    }
  }
}
