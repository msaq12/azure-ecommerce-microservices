{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Azure App Service for Product Service API"
  },
  "parameters": {
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "plan-furniture-dev",
      "metadata": {
        "description": "Name of the App Service Plan"
      }
    },
    "appServiceName": {
      "type": "string",
      "defaultValue": "app-product-service-dev",
      "metadata": {
        "description": "Name of the App Service (must be globally unique)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resources"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Environment name"
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "F1",
      "allowedValues": [
        "F1",
        "D1",
        "B1",
        "B2",
        "B3",
        "S1",
        "S2",
        "S3",
        "P1v2",
        "P2v2",
        "P3v2"
      ],
      "metadata": {
        "description": "App Service Plan SKU (F1 = Free, B1 = Basic, S1 = Standard)"
      }
    },
    "linuxFxVersion": {
      "type": "string",
      "defaultValue": "DOTNET|10.0",
      "metadata": {
        "description": "Runtime stack (DOTNET|10.0, etc.)"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault to grant access to"
      }
    },
    "keyVaultResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the Key Vault"
      }
    },
    "cosmosDbDatabaseName": {
      "type": "string",
      "defaultValue": "ProductsDB",
      "metadata": {
        "description": "Cosmos DB database name"
      }
    },
    "cosmosDbContainerName": {
      "type": "string",
      "defaultValue": "Products",
      "metadata": {
        "description": "Cosmos DB container name"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags to apply to resources"
      }
    }
  },
  "variables": {
    "defaultTags": {
      "Environment": "[parameters('environment')]",
      "Project": "FurnitureDropship",
      "ManagedBy": "ARM-Template",
      "Service": "ProductAPI"
    },
    "combinedTags": "[union(variables('defaultTags'), parameters('tags'))]",
    "isLinux": true
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('combinedTags')]",
      "sku": {
        "name": "[parameters('sku')]",
        "tier": "[if(equals(parameters('sku'), 'F1'), 'Free', if(equals(parameters('sku'), 'D1'), 'Shared', if(startsWith(parameters('sku'), 'B'), 'Basic', if(startsWith(parameters('sku'), 'S'), 'Standard', 'PremiumV2'))))]"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServiceName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('combinedTags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ],
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[parameters('linuxFxVersion')]",
          "alwaysOn": "[if(equals(parameters('sku'), 'F1'), false(), true())]",
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "http20Enabled": true,
          "appSettings": [
            {
              "name": "KeyVault__Uri",
              "value": "[concat('https://', parameters('keyVaultName'), '.vault.azure.net/')]"
            },
            {
              "name": "CosmosDb__DatabaseName",
              "value": "[parameters('cosmosDbDatabaseName')]"
            },
            {
              "name": "CosmosDb__ContainerName",
              "value": "[parameters('cosmosDbContainerName')]"
            },
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "[if(equals(parameters('environment'), 'prod'), 'Production', 'Development')]"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "appServicePlanName": {
      "type": "string",
      "value": "[parameters('appServicePlanName')]",
      "metadata": {
        "description": "Name of the App Service Plan"
      }
    },
    "appServiceName": {
      "type": "string",
      "value": "[parameters('appServiceName')]",
      "metadata": {
        "description": "Name of the App Service"
      }
    },
    "appServiceUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appServiceName'))).defaultHostName)]",
      "metadata": {
        "description": "URL of the deployed App Service"
      }
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('appServiceName')), '2023-12-01', 'Full').identity.principalId]",
      "metadata": {
        "description": "Principal ID of the Managed Identity (use this to grant Key Vault access)"
      }
    },
    "managedIdentityTenantId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('appServiceName')), '2023-12-01', 'Full').identity.tenantId]",
      "metadata": {
        "description": "Tenant ID of the Managed Identity"
      }
    }
  }
}