<policies>
    <inbound>
        <!-- Remove Server header for security -->
        <set-header name="X-Powered-By" exists-action="delete" />

        <!-- Add correlation ID for distributed tracing -->
        <set-header name="X-Correlation-Id" exists-action="override">
            <value>@(Guid.NewGuid().ToString())</value>
        </set-header>

        <!-- CORS: Allow all origins (for development) -->
        <cors allow-credentials="true">
            <allowed-origins>
                <origin>*</origin>
            </allowed-origins>
            <allowed-methods>
                <method>GET</method>
                <method>POST</method>
                <method>PUT</method>
                <method>DELETE</method>
                <method>OPTIONS</method>
            </allowed-methods>
            <allowed-headers>
                <header>*</header>
            </allowed-headers>
            <expose-headers>
                <header>*</header>
            </expose-headers>
        </cors>

        <!-- Rate limiting: 100 calls per minute per subscription -->
        <rate-limit-by-key calls="100" renewal-period="60" counter-key="@(context.Subscription?.Key ?? "anonymous")" />

        <!-- Log request -->
        <trace source="global-policy" severity="information">
            <message>@($"Request: {context.Request.Method} {context.Request.Url}")</message>
        </trace>
    </inbound>

    <backend>
        <!-- Forward to backend service -->
        <forward-request timeout="30" />
    </backend>

    <outbound>
        <!-- Cache GET responses for 5 minutes -->
        <cache-store duration="300" />

        <!-- Add custom response header -->
        <set-header name="X-API-Gateway" exists-action="override">
            <value>Azure-APIM</value>
        </set-header>

        <!-- Log response -->
        <trace source="global-policy" severity="information">
            <message>@($"Response: {context.Response.StatusCode}")</message>
        </trace>
    </outbound>

    <on-error>
        <!-- Custom error response -->
        <set-status code="500" reason="Internal Server Error" />
        <set-body>@{
            return new JObject(
                new JProperty("error", new JObject(
                    new JProperty("code", context.Response.StatusCode),
                    new JProperty("message", context.LastError.Message),
                    new JProperty("correlationId", context.Request.Headers.GetValueOrDefault("X-Correlation-Id", ""))
                ))
            ).ToString();
        }</set-body>
    </on-error>
</policies>
